<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.home.bottomsheet_fragments.AddMoneyFragment"
    android:background="@drawable/top_cornor_rounded"
    android:backgroundTint="@color/bg_dark_secondary">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/_12sdp">

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/divider_top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:dividerThickness="@dimen/_4sdp"
            app:dividerInsetStart="150dp"
            app:dividerInsetEnd="150dp"
            app:dividerColor="@color/white"
            android:layout_marginTop="@dimen/_12sdp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/_18sdp"
            android:layout_below="@+id/divider_top">
            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Money"
                android:maxLength="20"
                android:ellipsize="end"
                android:textColor="@color/white"
                android:textSize="@dimen/_20ssp"
                android:textStyle="bold"
                android:layout_centerInParent="true"
                />

<!--            <View-->
<!--                android:id="@+id/alertdialog_close_btn"-->
<!--                android:layout_width="@dimen/_16sdp"-->
<!--                android:layout_height="@dimen/_16sdp"-->
<!--                android:background="@drawable/ic_close"-->
<!--                android:backgroundTint="@color/white"-->
<!--                android:padding="@dimen/_12sdp"-->
<!--                android:layout_gravity="center"-->
<!--                android:layout_alignParentEnd="true"-->
<!--                android:layout_centerVertical="true"/>-->

            <ImageButton
                android:id="@+id/alertdialog_close_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_close"
                android:backgroundTint="@color/white"
                android:padding="@dimen/_8sdp"
                android:background="@android:color/transparent"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                app:tint="@color/white" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_centerHorizontal="true"
            android:padding="@dimen/_12sdp"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.cardview.widget.CardView
                android:layout_width="@dimen/_60sdp"
                android:layout_height="@dimen/_60sdp"
                app:cardCornerRadius="@dimen/_50sdp"
                app:cardBackgroundColor="@color/primary">
                <View
                    android:layout_width="@dimen/_30sdp"
                    android:layout_height="@dimen/_30sdp"
                    android:background="@drawable/ic_add"
                    android:layout_gravity="center"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter amount to add"
                android:textColor="@color/text_gray"
                android:fontFamily="@font/poppins_medium"
                android:textSize="@dimen/_14ssp"
                android:layout_marginTop="@dimen/_8sdp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹"
                    android:textSize="@dimen/_20ssp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_bold"/>
                <EditText
                    android:id="@+id/amount_editText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="0"
                    android:inputType="number"
                    android:backgroundTint="@color/bg_dark_secondary"
                    android:textColorHint="@color/white"
                    android:textSize="@dimen/_20ssp"
                    android:maxLines="1"
                    android:maxLength="4"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_bold"/>
            </LinearLayout>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You can add maximum of 5000"
                android:textColor="@color/text_gray"
                android:textSize="@dimen/_12ssp"
                android:layout_marginTop="@dimen/_8sdp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginVertical="@dimen/_4sdp">

                <LinearLayout
                    android:id="@+id/add_100"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_curved_border"
                    android:backgroundTint="@color/bg_light"
                    android:paddingHorizontal="@dimen/_10ssp"
                    android:paddingVertical="@dimen/_4sdp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+100"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_10ssp"
                        android:layout_gravity="center"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/add_300"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_curved_border"
                    android:backgroundTint="@color/bg_light"
                    android:paddingHorizontal="@dimen/_10ssp"
                    android:paddingVertical="@dimen/_4sdp"
                    android:layout_marginHorizontal="@dimen/_6sdp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+300"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_10ssp"
                        android:layout_gravity="center"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/add_500"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_curved_border"
                    android:backgroundTint="@color/bg_light"
                    android:paddingHorizontal="@dimen/_10ssp"
                    android:paddingVertical="@dimen/_4sdp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+500"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_10ssp"
                        android:layout_gravity="center"/>
                </LinearLayout>
            </LinearLayout>


        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_12sdp"
            android:layout_alignParentBottom="true">

            <LinearLayout
                android:id="@+id/left_section_add_money"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/add_money_btn">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAY USING"
                    android:textSize="@dimen/_10ssp"
                    android:textColor="@color/gray"/>
                <LinearLayout
                    android:id="@+id/change_payment_mode_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/_4sdp"
                    android:gravity="center">
                    <View
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="@dimen/_20sdp"
                        android:background="@drawable/ic_wallet"
                        android:backgroundTint="@color/white"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="cash"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_10ssp"
                        android:layout_marginHorizontal="@dimen/_6sdp"/>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/add_money_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/addMoney"
                android:textColor="@color/white"
                android:backgroundTint="@color/bg_light"
                app:layout_constraintStart_toEndOf="@+id/left_section_add_money"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </RelativeLayout>

</FrameLayout>