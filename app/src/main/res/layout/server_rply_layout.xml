<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginVertical="@dimen/_2sdp"
    >

    <TextView
        android:id="@+id/clientMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:text="sdjdsjk"
        android:background="@drawable/rounded_curved_border"
        android:backgroundTint="@color/bg_dark_secondary"
        android:layout_alignParentStart="true"
        android:layout_margin="@dimen/_4sdp"/>

    <TextView
        android:id="@+id/clientMessage_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="@dimen/_8ssp"
        android:text="122"
        android:layout_below="@+id/clientMessage"
        android:layout_marginHorizontal="@dimen/_4sdp"
        android:layout_alignParentStart="true"/>


</RelativeLayout>