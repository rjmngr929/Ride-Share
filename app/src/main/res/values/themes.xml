    <style name="NavigationMapRoute" tools:ignore="UnusedResources">
        <!-- Colors -->
        <item name="routeColor">@color/primary</item> <!-- The color of the route -->
        <item name="routeModerateCongestionColor">@color/colorTextLight</item><!-- The color of the route in case of moderate traffic -->
        <item name="routeSevereCongestionColor">@color/colorTextRed</item> <!-- The color of the route in case of heavy traffic -->
        <item name="routeShieldColor">@android:color/transparent</item> <!-- The color of the shield route means below the route -->
        <!-- Scales -->
        <item name="routeScale">0.9</item><!--Width of polyline-->
    </style>

