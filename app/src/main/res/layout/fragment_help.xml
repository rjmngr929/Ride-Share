        <ImageButton
            android:id="@+id/alertdialog_close_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_close"
            android:backgroundTint="@color/white"
            android:padding="@dimen/_8sdp"
            android:background="@android:color/transparent"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            app:tint="@color/white" />
    </RelativeLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your last ride"
                android:textColor="@color/white"
                android:textSize="@dimen/_18ssp"
                android:layout_marginHorizontal="@dimen/_16sdp"
                android:visibility="gone"
                android:fontFamily="@font/poppins_semibold"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="@dimen/_4sdp"
                android:layout_marginHorizontal="@dimen/_16sdp"
                android:visibility="gone">

                <androidx.cardview.widget.CardView
                    android:id="@+id/left_section_recentride"
                    android:layout_width="@dimen/_50sdp"
                    android:layout_height="@dimen/_50sdp"
                    android:orientation="vertical"
                    app:cardCornerRadius="@dimen/_10sdp"
                    app:cardBackgroundColor="@color/bg_light"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/middle_section_recentride">

                    <View
                        android:layout_width="@dimen/_25sdp"
                        android:layout_height="@dimen/_25sdp"
                        android:background="@drawable/ic_motor_icon"
                        android:layout_gravity="center"/>

                </androidx.cardview.widget.CardView>


                <LinearLayout
                    android:id="@+id/middle_section_recentride"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/_12sdp"
                    app:layout_constraintStart_toEndOf="@+id/left_section_recentride"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/right_section_recentride">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7867+2R6, Address G..."
                        android:textColor="@color/white"
                        android:textSize="@dimen/_14ssp"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="03 Sept 2024 | 09:37am"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_10ssp"/>


                </LinearLayout>

                <View
                    android:id="@+id/right_section_recentride"
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:background="@drawable/ic_forward_arrow"
                    app:layout_constraintStart_toEndOf="@+id/middle_section_recentride"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:dividerColor="@color/gray"
                android:layout_marginVertical="@dimen/_10sdp"
                android:visibility="gone"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All Topics"
                android:textColor="@color/white"
                android:textSize="@dimen/_18ssp"
                android:fontFamily="@font/poppins_semibold"
                android:layout_marginHorizontal="@dimen/_16sdp"/>

            <androidx.recyclerview.widget.RecyclerView
