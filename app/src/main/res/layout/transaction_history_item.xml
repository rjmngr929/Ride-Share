<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/bg_dark_secondary"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/_12sdp">
        <LinearLayout
            android:id="@+id/left_section_trxn_item"
            android:layout_width="@dimen/_50sdp"
            android:layout_height="@dimen/_50sdp"
            android:background="@drawable/rounded_border"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/middle_section_trxn_item">
            <View
                android:layout_width="@dimen/_25sdp"
                android:layout_height="@dimen/_25sdp"
                android:background="@drawable/ic_motor_icon"
                android:layout_gravity="center"/>
        </LinearLayout>


        <LinearLayout
            android:id="@+id/middle_section_trxn_item"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/_12sdp"
            app:layout_constraintStart_toEndOf="@+id/left_section_trxn_item"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/trxn_amount">
            <TextView
                android:id="@+id/debit_credit_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Debit"
                android:textColor="@color/white"
                android:textSize="@dimen/_14ssp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/payment_source"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="amazonpay"
                android:textColor="@color/text_gray"
                android:textSize="@dimen/_10ssp"/>

            <TextView
                android:id="@+id/trxn_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="17 Nov 24, 05:08 am"
                android:textColor="@color/text_gray"
                android:textSize="@dimen/_10ssp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/trxn_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹50.00"
            android:textColor="@color/text_gray"
            android:textSize="@dimen/_10ssp"
            android:layout_marginTop="@dimen/_10sdp"
            app:layout_constraintStart_toEndOf="@+id/middle_section_trxn_item"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:dividerColor="@color/gray"/>

</LinearLayout>