<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/auth_navigation"
    app:startDestination="@id/sendOtpFragment">

    <fragment
        android:id="@+id/sendOtpFragment"
        android:name="com.my.raido.ui.auth.fragment.SendOtpFragment"
        android:label="fragment_send_otp"
        tools:layout="@layout/fragment_send_otp" >
        <action
            android:id="@+id/action_sendOtpFragment_to_otpVerifyFragment"
            app:destination="@id/otpVerifyFragment" />
    </fragment>
    <fragment
        android:id="@+id/otpVerifyFragment"
        android:name="com.my.raido.ui.auth.fragment.OtpVerifyFragment"
        android:label="fragment_otp_verify"
        tools:layout="@layout/fragment_otp_verify" >
        <action
            android:id="@+id/action_otpVerifyFragment_to_sendOtpFragment"
            app:destination="@id/sendOtpFragment" />
    </fragment>
</navigation>