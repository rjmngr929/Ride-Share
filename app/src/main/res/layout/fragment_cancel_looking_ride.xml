<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.home.bottomsheet_fragments.ride_book.cancel_ride.CancelLookingRideFragment"
    android:background="@drawable/top_cornor_rounded"
    android:backgroundTint="@color/bg_dark_secondary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/top_cornor_rounded"
        android:backgroundTint="@color/bg_dark_secondary"
        android:orientation="vertical"
        android:padding="@dimen/_14sdp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Looking for Rider"
            android:textSize="@dimen/_18ssp"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_medium"
            android:textAlignment="center"/>

        <ProgressBar
            android:id="@+id/pBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:max="100"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/_12sdp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location Details"
                android:textColor="@color/white"
                android:textSize="@dimen/_12ssp"
                android:textStyle="bold"/>


            <LinearLayout
                android:id="@+id/expand_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginVertical="@dimen/_10sdp">

                <LinearLayout
                    android:layout_width="@dimen/_10sdp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_gravity="top"
                    android:layout_marginVertical="@dimen/_10sdp">

                    <View
                        android:layout_width="@dimen/_5sdp"
                        android:layout_height="@dimen/_5sdp"
                        android:background="@drawable/rounded_border"
                        android:backgroundTint="@color/white"/>

                    <View
                        android:id="@+id/verticalDivider"
                        android:layout_width="@dimen/_1sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:background="@drawable/vertically_dashed"
                        android:backgroundTint="@color/white"/>

                    <View
                        android:layout_width="@dimen/_5sdp"
                        android:layout_height="@dimen/_5sdp"
                        android:background="@drawable/rounded_border"
                        android:backgroundTint="@color/primary"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="@dimen/_8sdp">
                    <TextView
                        android:id="@+id/pickup_address_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Railway station "
                        android:textColor="@color/white"
                        android:textSize="@dimen/_12ssp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                    <TextView
                        android:id="@+id/pickup_sub_address_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Railway station "
                        android:textColor="@color/text_gray"
                        android:textSize="@dimen/_10ssp"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/drop_address_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Railway station "
                        android:textColor="@color/white"
                        android:textSize="@dimen/_12ssp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:layout_marginTop="@dimen/_16sdp"/>
                    <TextView
                        android:id="@+id/drop_sub_address_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Railway station "
                        android:textColor="@color/text_gray"
                        android:textSize="@dimen/_10ssp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_border"
            android:paddingVertical="@dimen/_4sdp"
            android:paddingHorizontal="@dimen/_8sdp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Fare"
                android:textColor="@color/gray"
                android:textSize="@dimen/_10ssp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"/>

            <TextView
                android:id="@+id/totalFare_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹ 14.73"
                android:textColor="@color/white"
                android:textSize="@dimen/_12ssp"
                android:fontFamily="@font/poppins_medium"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>

        </RelativeLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/_6sdp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancel_ride_back_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_4sdp"
                android:backgroundTint="@color/bg_light"
                android:text="@string/Back"
                android:textColor="@color/primary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/cancel_ride_btn"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancel_ride_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_4sdp"
                android:backgroundTint="@color/bg_light"
                android:text="@string/cancel"
                android:textColor="@color/primary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/cancel_ride_back_btn"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

</FrameLayout>