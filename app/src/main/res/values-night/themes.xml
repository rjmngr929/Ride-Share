<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="AppDarkTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->

        <item name="colorPrimary">@color/primary</item> <!-- Component Background Color  -->
        <item name="colorPrimaryDark">@color/darkMineShaft</item>
        <item name="colorAccent">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>  <!-- Button Text Color  -->

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!--        <item name="bottomSheetDialogTheme">@style/AppBottomSheetDialogTheme</item>-->



        <item name="textInputStyle">@style/ThemeOverlay.CustomTextField</item>

    </style>

    <style name="ThemeOverlay.CustomTextField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/box_stroke_color</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="cursorColor">@color/primary</item>
    </style>

    <style name="Theme.Raido" parent="AppDarkTheme" />

    <style name="Splashscreen" parent="Theme.Raido">
        <!--        <item name="android:statusBarColor">@color/black</item>-->
        <item name="android:windowBackground">@drawable/splashscreen</item>
    </style>

    <!--    Transparent Alert Background-->
    <style name="MyDialogStyle_transparent" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowMinWidthMinor">75%</item>
    </style>
    <!--    Transparent Alert Background-->

    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@android:anim/slide_in_left</item>
        <item name="android:windowExitAnimation">@android:anim/slide_out_right</item>
    </style>

    <!-- Date Time Picker  -->
    <style name="SpinnerDatePickerDialog" parent="@android:style/Theme.Holo.Light.Dialog">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:calendarViewShown">false</item>
        <item name="android:datePickerMode">spinner</item>
    </style>
    <!-- Date Time Picker  -->

    <style name="CustomRatingBar" parent="Widget.AppCompat.RatingBar">
        <item name="android:progressDrawable">@drawable/ratting_selector</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:maxHeight">48dp</item>
    </style>

    <style name="NavigationMapRoute">

        // for route filling color

        <item name="routelowCongestionColor">#555555</item>

        <item name="routeModerateCongestionColor">#555555</item>

        <item name="routeHeavyCongestionColor">#ffffff</item>

        <item name="routeJamCongestionColor">#000000</item>

        <item name="android:width">1dp</item>
        <item name="thickness">1dp</item>



        // for route shield/ boundary color

        <!--        <item name="routeShieldHeavyColor">#000000</item>-->

        <!--        <item name="routeShieldJamColor">#000000</item>-->

        <!--        <item name="routeShieldLowColor">#000000</item>-->

        <!--        <item name="routeShieldModerateColor">#000000</item>-->

        <item name="routeSevereCongestionColor">@color/mapbox_navigation_route_layer_congestion_red</item>
        <item name="routeShieldColor">@color/mapbox_navigation_route_shield_layer_color</item>
        <item name="routeShieldLowColor">@color/mapbox_navigation_route_shield_low_color</item>
        <item name="routeShieldModerateColor">@color/mapbox_navigation_route_shield_moderate_color</item>
        <item name="routeShieldHeavyColor">@color/mapbox_navigation_route_shield_heavy_color</item>
        <item name="routeShieldJamColor">@color/mapbox_navigation_route_shield_jam_color</item>

        <item name="enableSoftTurnArrowState">true</item>
        <item name="showTimeMarkerView">false</item>
        <item name="originWaypointIcon">@drawable/ic_close</item>


    </style>

</resources>