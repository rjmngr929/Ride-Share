<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:fillViewport="true"
    android:scrollIndicators="none"
    android:scrollbars="none"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.home.HomeActivity"
    android:background="@color/bg_dark">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/topbar_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/_12sdp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:id="@+id/left_section_topbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/setting_btn_dashboard"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <TextView
                    android:id="@+id/hello_name_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hello, Guddu!"
                    android:textSize="@dimen/_24ssp"
                    android:textColor="@color/white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Where do you want to go?"
                    android:textSize="@dimen/_10ssp"
                    android:textColor="@color/gray"
                    android:fontFamily="@font/poppins_medium"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/setting_btn_dashboard"
                android:layout_width="@dimen/_40sdp"
                android:layout_height="@dimen/_40sdp"
                android:src="@drawable/ic_settings"
                android:backgroundTint="@color/bg_light"
                android:background="@drawable/bg_circle_black"
                app:tint="@color/white"
                app:layout_constraintStart_toEndOf="@id/left_section_topbar"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/section_one_dashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_12sdp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/topbar_layout"
            app:layout_constraintBottom_toTopOf="@+id/section_two_dashboard">

            <LinearLayout
                android:id="@+id/section_one_left_dashboard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/_8sdp"
                android:layout_marginEnd="@dimen/_6sdp"
                android:background="@drawable/rounded_border"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/section_one_right_dashboard"
                app:layout_constraintBottom_toBottomOf="parent">

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentStart="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Raido Wallet"
                            android:textSize="@dimen/_12ssp"
                            android:textColor="@color/white"/>
                        <TextView
                            android:id="@+id/walletBalanceText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" ₹0.0"
                            android:textSize="@dimen/_16ssp"
                            android:textColor="@color/white"
                            android:fontFamily="@font/roboto_medium"
                            android:layout_gravity="start"/>
                    </LinearLayout>

                    <View
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="@dimen/_20sdp"
                        android:background="@drawable/ic_wallet"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>

<!--                <TextView-->
<!--                    android:id="@+id/add_money_btn"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:text="+ Add Money"-->
<!--                    android:textColor="@color/white"-->
<!--                    android:textSize="@dimen/_10ssp"-->
<!--                    android:padding="@dimen/_10sdp"/>-->

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/add_money_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                    android:padding="10dp"
                    android:text="Add Money"
                    app:cornerRadius="@dimen/_6sdp"
                    app:icon="@android:drawable/ic_input_add"
                    android:layout_marginTop="@dimen/_2sdp"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_one_right_dashboard"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:orientation="vertical"
                android:padding="@dimen/_16sdp"
                android:gravity="center"
                android:layout_marginStart="@dimen/_6sdp"
                android:background="@drawable/rounded_border"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@+id/section_one_left_dashboard"
                app:layout_constraintEnd_toEndOf="parent">

                    <View
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_30sdp"
                        android:background="@drawable/ic_new_trip"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="New Trip"
                        android:textSize="@dimen/_14ssp"
                        android:textColor="@color/white"/>


            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/section_two_dashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_12sdp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/section_one_dashboard">

            <LinearLayout
                android:id="@+id/section_two_left_dashboard"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:orientation="vertical"
                android:padding="@dimen/_16sdp"
                android:gravity="center"
                android:layout_marginEnd="@dimen/_10sdp"
                android:background="@drawable/rounded_border"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <View
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_40sdp"
                    android:background="@drawable/ic_truck"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Send Item"
                    android:textSize="@dimen/_14ssp"
                    android:textColor="@color/white"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/section_two_right_dashboard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_border"
                android:padding="@dimen/_12sdp"
                android:layout_marginStart="@dimen/_10sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@+id/section_two_left_dashboard"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent"
                    android:textSize="@dimen/_14ssp"
                    android:textColor="@color/white"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="@dimen/_8sdp">
                    <View
                        android:layout_width="@dimen/_18sdp"
                        android:layout_height="@dimen/_24sdp"
                        android:background="@drawable/ic_motor_icon"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginHorizontal="@dimen/_10sdp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7867+2R6, Address G..."
                            android:textSize="@dimen/_10ssp"
                            android:textColor="@color/white"
                            android:layout_marginVertical="@dimen/_2sdp"
                            android:maxLines="1"
                            android:ellipsize="end"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="03Sept 2024 | 09:37am"
                            android:textSize="@dimen/_10ssp"
                            android:textColor="@color/white"
                            android:layout_marginVertical="@dimen/_2sdp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹50.0 | Completed"
                            android:textSize="@dimen/_10ssp"
                            android:textColor="@color/white"
                            android:layout_marginVertical="@dimen/_2sdp"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/section_three_dashboard"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:minHeight="@dimen/_200sdp"
            android:orientation="vertical"
            android:layout_margin="@dimen/_12sdp"
            app:cardCornerRadius="@dimen/_12sdp"
            app:cardBackgroundColor="@color/bg_light"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@+id/section_two_dashboard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/searchBar_dashboard">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.ola.maps.navigation.v5.navigation.OlaMapView
                    android:id="@+id/mapView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_centerInParent="true"/>

                <ImageButton
                    android:id="@+id/gps_location_btn"
                    android:layout_width="@dimen/_30sdp"
                    android:layout_height="@dimen/_30sdp"
                    android:src="@drawable/ic_gps_icon"
                    android:background="@android:color/transparent"
                    android:scaleType="fitXY"
                    android:padding="0dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:layout_margin="@dimen/_10sdp"/>

            </RelativeLayout>


        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/searchBar_dashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_light"
            app:cardElevation="0dp"
            app:cardCornerRadius="@dimen/_50sdp"
            android:layout_margin="@dimen/_12sdp"
            app:contentPadding="@dimen/_10sdp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/section_three_dashboard">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="@dimen/_8sdp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true">
                    <View
                        android:layout_width="@dimen/_15sdp"
                        android:layout_height="@dimen/_15sdp"
                        android:background="@drawable/ic_search"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Where to?"
                        android:textSize="@dimen/_12sdp"
                        android:textColor="@color/white"
                        android:layout_marginHorizontal="@dimen/_8sdp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:visibility="invisible"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true">

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="@dimen/_1sdp"
                        android:layout_height="@dimen/_14sdp"
                        android:layout_marginHorizontal="@dimen/_10sdp"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="@dimen/_50sdp"
                        app:cardBackgroundColor="@color/bg_dark_secondary"
                        app:cardElevation="0dp"
                        app:contentPadding="@dimen/_4sdp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:paddingHorizontal="@dimen/_8sdp">
                            <View
                                android:layout_width="@dimen/_14sdp"
                                android:layout_height="@dimen/_14sdp"
                                android:background="@drawable/ic_clock"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Now"
                                android:textSize="@dimen/_12sdp"
                                android:textColor="@color/white"
                                android:layout_marginHorizontal="@dimen/_4sdp"/>

                            <View
                                android:layout_width="@dimen/_10sdp"
                                android:layout_height="@dimen/_10sdp"
                                android:background="@drawable/ic_down_arrow"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>


                </LinearLayout>
            </RelativeLayout>

        </androidx.cardview.widget.CardView>

        <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_section_dashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/_12sdp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/searchBar_dashboard"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/bike_box"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/auto_box">
            <androidx.cardview.widget.CardView
                android:id="@+id/select_bike_bg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="0dp"
                app:cardCornerRadius="@dimen/_12sdp" >
                <View
                    android:id="@+id/bike_ic"
                    android:layout_width="@dimen/_20sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:background="@drawable/ic_motor_icon"
                    android:backgroundTint="@color/black"
                    android:layout_margin="@dimen/_12sdp"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bike"
                android:textSize="@dimen/_12ssp"
                android:textColor="@color/white"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/auto_box"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintStart_toEndOf="@+id/bike_box"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/cab_box">
        <androidx.cardview.widget.CardView
            android:id="@+id/select_auto_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_light"
            app:cardElevation="0dp"
            app:cardCornerRadius="@dimen/_12sdp">

            <View
                android:id="@+id/auto_ic"
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:background="@drawable/ic_auto"
                android:layout_margin="@dimen/_12sdp"/>

        </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto"
                android:textSize="@dimen/_12ssp"
                android:textColor="@color/white"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cab_box"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintStart_toEndOf="@+id/auto_box"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/parcel_box">
                <androidx.cardview.widget.CardView
                    android:id="@+id/select_cab_bg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/bg_light"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="@dimen/_12sdp">

                    <View
                        android:id="@+id/cab_ic"
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="@dimen/_20sdp"
                        android:background="@drawable/ic_cab"
                        android:layout_margin="@dimen/_12sdp"/>

                </androidx.cardview.widget.CardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cab"
                    android:textSize="@dimen/_12ssp"
                    android:textColor="@color/white"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/parcel_box"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="@+id/cab_box"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/bike_lite_box">
        <androidx.cardview.widget.CardView
            android:id="@+id/select_parcel_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_light"
            app:cardElevation="0dp"
            app:cardCornerRadius="@dimen/_12sdp">

            <View
                android:id="@+id/parcel_ic"
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:background="@drawable/ic_parcel"
                android:layout_margin="@dimen/_12sdp"/>

        </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Parcel"
                android:textSize="@dimen/_12ssp"
                android:textColor="@color/white"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/bike_lite_box"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintStart_toEndOf="@+id/parcel_box"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
        <androidx.cardview.widget.CardView
            android:id="@+id/select_bikelite_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_light"
            app:cardElevation="0dp"
            app:cardCornerRadius="@dimen/_12sdp">

            <View
                android:id="@+id/bikelite_ic"
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:background="@drawable/ic_motor_icon"
                android:layout_margin="@dimen/_12sdp"/>

        </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bike lite"
                android:textSize="@dimen/_12ssp"
                android:textColor="@color/white"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>