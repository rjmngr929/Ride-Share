<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.home.bottomsheet_fragments.driver.AssignDriverFragment"
    android:background="@drawable/top_cornor_rounded"
    android:backgroundTint="@color/bg_dark_secondary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/_16sdp"
                android:paddingVertical="@dimen/_8sdp"
                android:background="@drawable/top_cornor_rounded"
                android:backgroundTint="@color/bg_light"
                android:layout_marginBottom="@dimen/_8sdp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="The driver will arive in "
                    android:textColor="@color/white"
                    android:textSize="@dimen/_12ssp"
                    android:layout_alignParentStart="true"/>

                <TextView
                    android:id="@+id/away_time_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6 min"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/_12ssp"
                    android:layout_alignParentEnd="true"/>

            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/_50sdp"
                app:cardBackgroundColor="@color/bg_light"
                android:layout_margin="@dimen/_12sdp"
                app:contentPadding="@dimen/_12sdp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true">

                        <TextView
                            android:id="@+id/pin_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pin : 3420"
                            android:textColor="@color/white"
                            android:textSize="@dimen/_12ssp"/>

                        <LinearLayout
                            android:id="@+id/vehicle_detail_layout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/vehicle_model_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Royal Enfield"
                                android:textColor="@color/white"
                                android:textSize="@dimen/_10ssp"
                                android:maxLength="30"
                                android:ellipsize="end"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="|"
                                android:textColor="@color/white"
                                android:textSize="@dimen/_10ssp"
                                android:layout_marginHorizontal="@dimen/_4sdp"/>

                            <TextView
                                android:id="@+id/vehicle_number_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DL7CD8977"
                                android:textColor="@color/white"
                                android:textSize="@dimen/_10ssp"
                                android:maxLength="10"/>

                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:id="@+id/vehicle_type_icon"
                        android:layout_width="@dimen/_24sdp"
                        android:layout_height="@dimen/_24sdp"
                        android:background="@drawable/ic_motor_icon"
                        android:backgroundTint="@color/primary"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>

                </RelativeLayout>

            </androidx.cardview.widget.CardView>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/_12sdp">

                <LinearLayout
                    android:id="@+id/short_profile_left"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/short_profile_right">

                    <androidx.cardview.widget.CardView
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        app:cardCornerRadius="@dimen/_50sdp"
                        app:cardBackgroundColor="@color/white"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="center"
                        android:layout_marginStart="@dimen/_8sdp">

                        <TextView
                            android:id="@+id/driver_name_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Driver’s Name"
                            android:textSize="@dimen/_12ssp"
                            android:textColor="@color/white"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap rated driver"
                            android:textSize="@dimen/_10ssp"
                            android:textColor="@color/white"/>

                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/short_profile_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toEndOf="@+id/short_profile_left"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.cardview.widget.CardView
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="@dimen/_30sdp"
                        app:cardBackgroundColor="@color/bg_light"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_marginHorizontal="@dimen/_4sdp">

                        <View
                            android:layout_width="@dimen/_15sdp"
                            android:layout_height="@dimen/_15sdp"
                            android:background="@drawable/ic_call_icon"
                            android:layout_gravity="center"/>

                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="@dimen/_30sdp"
                        app:cardBackgroundColor="@color/bg_light"
                        app:cardCornerRadius="@dimen/_10sdp"
                        android:layout_marginHorizontal="@dimen/_4sdp">

                        <View
                            android:layout_width="@dimen/_15sdp"
                            android:layout_height="@dimen/_15sdp"
                            android:background="@drawable/ic_messages_icon"
                            android:layout_gravity="center"/>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:dividerColor="@color/gray"
                app:dividerInsetStart="@dimen/_14sdp"
                app:dividerInsetEnd="@dimen/_14sdp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/_20sdp"
                app:cardBackgroundColor="@color/bg_light"
                android:layout_margin="@dimen/_12sdp"
                app:contentPadding="@dimen/_10sdp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/_12sdp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/arrow_icon"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pickup Point"
                            android:textColor="@color/gray"
                            android:textSize="@dimen/_12ssp"/>

                        <TextView
                            android:id="@+id/collapse_pickup_address_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Railway station "
                            android:textColor="@color/white"
                            android:textSize="@dimen/_14ssp"
                            android:maxLength="30"
                            android:ellipsize="end"
                            android:visibility="visible"/>

                        <LinearLayout
                            android:id="@+id/expand_layout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginVertical="@dimen/_10sdp"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="@dimen/_10sdp"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:layout_gravity="top"
                                android:layout_marginVertical="@dimen/_4sdp">

                                <View
                                    android:layout_width="@dimen/_5sdp"
                                    android:layout_height="@dimen/_5sdp"
                                    android:background="@drawable/rounded_border"
                                    android:backgroundTint="@color/white"/>

                                <View
                                    android:id="@+id/verticalDivider"
                                    android:layout_width="@dimen/_1sdp"
                                    android:layout_height="@dimen/_60sdp"
                                    android:background="@drawable/vertically_dashed"
                                    android:backgroundTint="@color/white"/>

                                <View
                                    android:layout_width="@dimen/_5sdp"
                                    android:layout_height="@dimen/_5sdp"
                                    android:background="@drawable/rounded_border"
                                    android:backgroundTint="@color/primary"/>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginHorizontal="@dimen/_8sdp">
                                <TextView
                                    android:id="@+id/pickup_address_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Railway station "
                                    android:textColor="@color/white"
                                    android:textSize="@dimen/_14ssp"
                                    android:maxLines="1"
                                    android:ellipsize="end"/>
                                <TextView
                                    android:id="@+id/pickup_sub_address_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Railway station "
                                    android:textColor="@color/white"
                                    android:textSize="@dimen/_14ssp"
                                    android:maxLines="1"
                                    android:ellipsize="end"/>

                                <TextView
                                    android:id="@+id/drop_address_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Railway station "
                                    android:textColor="@color/white"
                                    android:textSize="@dimen/_14ssp"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:layout_marginTop="@dimen/_16sdp"/>
                                <TextView
                                    android:id="@+id/drop_sub_address_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Railway station "
                                    android:textColor="@color/white"
                                    android:textSize="@dimen/_14ssp"
                                    android:maxLines="1"
                                    android:ellipsize="end"/>
                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:id="@+id/arrow_icon_btn"
                        android:layout_width="@dimen/_16sdp"
                        android:layout_height="@dimen/_16sdp"
                        android:background="@drawable/ic_down_arrow"
                        android:backgroundTint="@color/white"
                        android:layout_margin="@dimen/_12sdp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>




            </androidx.cardview.widget.CardView>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/_14sdp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Fare"
                    android:textColor="@color/gray"
                    android:textSize="@dimen/_12ssp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"/>

                <TextView
                    android:id="@+id/totalFare_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ 14.73"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_14ssp"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>

            </RelativeLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancel_ride_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cancelRide"
                android:textColor="@color/primary"
                android:backgroundTint="@color/bg_light"
                android:layout_margin="@dimen/_14sdp"
                android:paddingVertical="@dimen/_10sdp"/>

        </LinearLayout>

</FrameLayout>